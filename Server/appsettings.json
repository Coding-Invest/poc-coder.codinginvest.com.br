{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Settings": {
    "ClientUrl": "http://host.docker.internal"
  },
  "Git": {
    "TargetDirectory": "./repos",
    "RepositoryUrl": "https://{0}@github.com/your-username/your-repo.git",
    "PersonalAccessToken": "YOUR_GITHUB_PAT_HERE"
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Email": "your-email@gmail.com",
    "Password": "your-app-password"
  },
  "Google": {
    "ApiKey": "YOUR_GOOGLE_API_KEY_HERE",
    "Cx": "YOUR_GOOGLE_CX_HERE"
  }
}